# PostgreSQL
POSTGRES_USER=gscores
POSTGRES_PASSWORD=gscores_pwd
POSTGRES_DB=gscores
POSTGRES_PORT=5433

# Backend
BACKEND_PORT=4000

# Frontend (Docker nginx host port)
FRONTEND_PORT=8080
# Connection string used by Prisma (host is "db" inside docker network, "localhost" when running locally)
DATABASE_URL=postgresql://gscores:gscores_pwd@127.0.0.1:5433/gscores?schema=public

# Frontend
VITE_API_URL=http://localhost:4000/api
